{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kedi",
  "version": "0.3.0",
  "identifier": "dev.kedi.terminal",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "A governed terminal",
    "longDescription": "kedi — a fast, governed terminal (tabs, tiling, command palette, shell integration).",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "linux": {
      "deb": { "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"] }
    }
  }
}
